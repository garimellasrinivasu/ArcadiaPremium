# =========================
# ArcadiaPremium .gitignore
# =========================

# --- Frontend ---
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# --- Backend ---
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.jar
backend/*.war

# --- IDE ---
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Environment ---
.env
